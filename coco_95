SQL for correlation:

WITH events AS (
  SELECT 'COST_SPIKE' AS domain, warehouse_name AS entity, start_time AS event_time, credits_used AS magnitude
  FROM SNOWFLAKE.ACCOUNT_USAGE.WAREHOUSE_METERING_HISTORY
  WHERE credits_used > (SELECT AVG(credits_used) * 2 FROM ... WHERE ...)
    AND start_time >= DATEADD('hour', -:window, CURRENT_TIMESTAMP())
  UNION ALL
  SELECT 'QUERY_FAILURE', warehouse_name, start_time, total_elapsed_time
  FROM SNOWFLAKE.ACCOUNT_USAGE.QUERY_HISTORY
  WHERE execution_status = 'FAIL' AND start_time >= DATEADD('hour', -:window, CURRENT_TIMESTAMP())
  UNION ALL
  SELECT 'TASK_FAILURE', database_name || '.' || name, scheduled_time, 1
  FROM SNOWFLAKE.ACCOUNT_USAGE.TASK_HISTORY
  WHERE state = 'FAILED' AND scheduled_time >= DATEADD('hour', -:window, CURRENT_TIMESTAMP())
  UNION ALL
  SELECT 'LOGIN_FAILURE', user_name, event_timestamp, 1
  FROM SNOWFLAKE.ACCOUNT_USAGE.LOGIN_HISTORY
  WHERE is_success = 'NO' AND event_timestamp >= DATEADD('hour', -:window, CURRENT_TIMESTAMP())
)
SELECT
  DATE_TRUNC('hour', event_time) AS incident_hour,
  ARRAY_AGG(DISTINCT domain) AS involved_domains,
  ARRAY_AGG(DISTINCT entity) AS involved_entities,
  COUNT(*) AS event_count,
  COUNT(DISTINCT domain) AS domain_count
FROM events
GROUP BY incident_hour
HAVING domain_count >= 2
ORDER BY event_count DESC;
