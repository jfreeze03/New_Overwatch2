CREATE OR REPLACE VIEW DBA_MAINT_DB.OVERWATCH.OVERWATCH_PIPELINE_SLA_STATUS_V AS
SELECT
  s.DATABASE_NAME, s.SCHEMA_NAME, s.TABLE_NAME,
  s.SLA_FRESHNESS_HOURS,
  s.OWNER,
  s.COMPANY,
  t.LAST_ALTERED,
  DATEDIFF('hour', t.LAST_ALTERED, CURRENT_TIMESTAMP()) AS HOURS_SINCE_CHANGE,
  IFF(HOURS_SINCE_CHANGE <= s.SLA_FRESHNESS_HOURS, 'MET', 'BREACHED') AS SLA_STATUS
FROM DBA_MAINT_DB.OVERWATCH.OVERWATCH_PIPELINE_SLA s
JOIN SNOWFLAKE.ACCOUNT_USAGE.TABLES t
  ON t.TABLE_CATALOG = s.DATABASE_NAME
  AND t.TABLE_SCHEMA = s.SCHEMA_NAME
  AND t.TABLE_NAME = s.TABLE_NAME
  AND t.DELETED IS NULL
WHERE s.ENABLED = TRUE;
