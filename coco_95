4.5 — Predictive SLA Breach Detection
Instructions for AI:

Create utils/predictive_sla.py:

def build_predictive_sla_sql(days_history: int = 30) -> str:
    return f"""
    WITH freshness_history AS (
      SELECT
        TABLE_CATALOG AS database_name,
        TABLE_SCHEMA AS schema_name,
        TABLE_NAME AS table_name,
        DATE_TRUNC('day', LAST_ALTERED) AS altered_date,
        DATEDIFF('hour', LAG(LAST_ALTERED) OVER (
          PARTITION BY TABLE_CATALOG, TABLE_SCHEMA, TABLE_NAME ORDER BY LAST_ALTERED
        ), LAST_ALTERED) AS refresh_interval_hours
