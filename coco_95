class SafeQuery:
    def __init__(self, template: str):
        self.template = template
        self.params = []
    
    def bind(self, value) -> 'SafeQuery':
        self.params.append(value)
        return self
    
    def execute(self, session) -> pd.DataFrame:
        return session.sql(self.template, params=self.params).to_pandas()
