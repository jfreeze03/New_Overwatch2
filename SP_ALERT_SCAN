SELECT 'last event raised' AS CHECK, MAX(RAISED_AT)::VARCHAR AS VALUE FROM ALERT_EVENTS
UNION ALL
SELECT 'events last 48h', COUNT(*)::VARCHAR FROM ALERT_EVENTS
 WHERE RAISED_AT >= DATEADD('hour', -48, CURRENT_TIMESTAMP())
UNION ALL
SELECT 'open events now', COUNT(*)::VARCHAR FROM ALERT_EVENTS WHERE STATUS = 'OPEN'
UNION ALL
SELECT 'last successful send', MAX(SENT_AT)::VARCHAR FROM ALERT_DELIVERIES
UNION ALL
SELECT 'sender errors last 7d', COUNT(*)::VARCHAR FROM APP_ERROR_LOG
 WHERE PAGE = 'NotifyWebhook' AND LOGGED_AT >= DATEADD('day', -7, CURRENT_TIMESTAMP())
UNION ALL
SELECT 'route: ' || ROUTE_ID || '  family=' || FAMILY || '  minsev=' || MIN_SEVERITY
       || '  company=' || COALESCE(COMPANY_FILTER, 'ALL'),
       IFF(ENABLED, 'ENABLED', 'DISABLED')
FROM ALERT_ROUTES;
