    // Executive Landing - Cost Trend Chart
    (function() {
      var ctx = document.getElementById('costTrend').getContext('2d');
      var labels = [];
      var actual = [];
      var forecast = [];
      var budget = [];

      for (var i = 30; i >= 0; i--) {
        var d = new Date();
        d.setDate(d.getDate() - i);
        labels.push((d.getMonth()+1) + '/' + d.getDate());
        var base = 450 + Math.random() * 80;
        if (i > 5) {
          actual.push(Math.round(base));
          forecast.push(null);
        } else if (i === 5) {
          actual.push(Math.round(base));
          forecast.push(Math.round(base));
        } else {
          actual.push(null);
          forecast.push(Math.round(base + Math.random() * 20));
        }
        budget.push(500);
      }

      new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [
            {
              label: 'Actual',
              data: actual,
              borderColor: '#29B5E8',
              backgroundColor: 'rgba(41, 181, 232, 0.1)',
              fill: true,
              tension: 0.3,
              pointRadius: 0,
              borderWidth: 2
