              label: 'Budget',
              data: budget,
              borderColor: '#fbbf24',
              borderDash: [2, 4],
              pointRadius: 0,
              borderWidth: 1.5,
              fill: false
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { intersect: false, mode: 'index' },
          plugins: { legend: { display: false } },
