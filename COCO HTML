      <!-- Platform Operating Score + Breakdown -->
      <div class="score-section" id="executive-landing">
        <div class="score-ring-container">
          <svg viewBox="0 0 120 120" width="120" height="120">
            <circle cx="60" cy="60" r="50" class="score-ring-bg"/>
            <circle cx="60" cy="60" r="50" class="score-ring-fill"
              stroke-dasharray="314" stroke-dashoffset="47"/>
          </svg>
          <div class="score-label">
            <div class="number">85</div>
            <div class="sublabel">Platform Score</div>
          </div>
        </div>
        <div class="score-breakdown">
          <div class="score-item">
            <span class="score-dot" style="background:var(--accent-green)"></span>
            <span class="name">Cost Health</span>
            <span class="value">92</span>
          </div>
          <div class="score-item">
            <span class="score-dot" style="background:var(--accent-green)"></span>
            <span class="name">Pipeline Success</span>
            <span class="value">98</span>
          </div>
          <div class="score-item">
            <span class="score-dot" style="background:var(--accent-amber)"></span>
            <span class="name">Security Posture</span>
            <span class="value">74</span>
          </div>
          <div class="score-item">
            <span class="score-dot" style="background:var(--accent-green)"></span>
            <span class="name">Alert Health</span>
            <span class="value">88</span>
