        "preview_sql": "SHOW WAREHOUSES LIKE '{entity}';",
        "rollback_template": "ALTER WAREHOUSE {entity} SET WAREHOUSE_SIZE = '{original_value}';",
        "requires_role": "SYSADMIN",
        "audit_table": "OVERWATCH_REMEDIATION_LOG",
    },
}

def execute_safe_remediation(
    session, 
    action_type: str, 
    entity: str, 
    value: str, 
    original_value: str,
    action_id: str,
    approved_by: str,
) -> dict:
    """Execute a pre-approved safe remediation with audit trail."""
    config = SAFE_REMEDIATIONS.get(action_type)
    if not config:
        return {"success": False, "error": "Unknown remediation type"}
    
    # Verify role
    current_role = session.sql("SELECT CURRENT_ROLE()").collect()[0][0]
    if config["requires_role"] not in current_role.upper():
        return {"success": False, "error": f"Requires {config['requires_role']} role"}
    
    # Execute
    sql = config["template"].format(entity=safe_identifier(entity), value=value)
    rollback_sql = config["rollback_template"].format(
        entity=safe_identifier(entity), original_value=original_value
    )
    
    try:
        session.sql(sql).collect()
        # Audit log
        session.sql(f"""
            INSERT INTO DBA_MAINT_DB.OVERWATCH.OVERWATCH_REMEDIATION_LOG
            (ACTION_ID, ACTION_TYPE, ENTITY, SQL_EXECUTED, ROLLBACK_SQL, EXECUTED_BY, APPROVED_BY, EXECUTED_AT)
            VALUES ({sql_literal(action_id)}, {sql_literal(action_type)}, {sql_literal(entity)},
                    {sql_literal(sql)}, {sql_literal(rollback_sql)}, CURRENT_USER(), 
                    {sql_literal(approved_by)}, CURRENT_TIMESTAMP())
        """).collect()
        return {"success": True, "sql_executed": sql, "rollback_sql": rollback_sql}
    except Exception as e:
        return {"success": False, "error": str(e)}
