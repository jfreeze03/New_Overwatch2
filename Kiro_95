def maybe_run_session_gc():
    """Prune stale transient state if accumulation exceeds threshold."""
    now = time.time()
    last_run = st.session_state.get(_GC_LAST_RUN_KEY, 0)
    if now - last_run < _GC_INTERVAL_MINUTES * 60:
        return
    if len(st.session_state) < _MAX_SESSION_STATE_KEYS:
        return
    
    # Remove stale timestamp keys older than 30 minutes
    stale_keys = []
    for key in list(st.session_state.keys()):
        if key.startswith("_ts_"):
            ts = st.session_state.get(key)
            if isinstance(ts, (int, float)) and now - ts > 1800:
                stale_keys.append(key)
        elif key.startswith("df_") and key not in _active_section_data_keys():
            stale_keys.append(key)
    
    for key in stale_keys:
        st.session_state.pop(key, None)
    st.session_state[_GC_LAST_RUN_KEY] = now
