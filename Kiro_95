# utils/measured_savings.py

def measure_recommendation_impact(
    session,
    action_id: str,
    entity: str,
    entity_type: str,
    baseline_start: date,
    baseline_end: date,
    post_action_start: date,
    post_action_end: date,
) -> dict:
    """Automatically measure credit delta after a recommendation was actioned."""
    
    if entity_type == "Warehouse":
        sql = f"""
        SELECT
            '{action_id}' AS action_id,
            SUM(IFF(DATE(start_time) BETWEEN '{baseline_start}' AND '{baseline_end}', credits_used, 0)) 
                / NULLIF(DATEDIFF('day', '{baseline_start}', '{baseline_end}'), 0) AS baseline_daily_credits,
            SUM(IFF(DATE(start_time) BETWEEN '{post_action_start}' AND '{post_action_end}', credits_used, 0))
                / NULLIF(DATEDIFF('day', '{post_action_start}', '{post_action_end}'), 0) AS post_action_daily_credits
        FROM SNOWFLAKE.ACCOUNT_USAGE.WAREHOUSE_METERING_HISTORY
        WHERE warehouse_name = {sql_literal(entity)}
          AND start_time >= '{baseline_start}'
        """
        result = run_query(sql)
        if result.empty:
            return {"verified": False, "reason": "No metering data"}
        
        baseline = float(result.iloc[0]["BASELINE_DAILY_CREDITS"] or 0)
        post = float(result.iloc[0]["POST_ACTION_DAILY_CREDITS"] or 0)
        savings_daily = baseline - post
        
        return {
            "verified": savings_daily > 0,
            "baseline_daily_credits": baseline,
            "post_action_daily_credits": post,
            "savings_daily_credits": savings_daily,
            "savings_monthly_credits": savings_daily * 30,
            "savings_monthly_dollars": credits_to_dollars(savings_daily * 30),
            "measurement_method": "WAREHOUSE_METERING_HISTORY 7-day pre/post comparison",
        }
```

