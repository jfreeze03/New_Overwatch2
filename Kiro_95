    "idle_warehouse_autosuspend": {
        "template": "ALTER WAREHOUSE {entity} SET AUTO_SUSPEND = {value};",
        "preview_sql": "SHOW PARAMETERS IN WAREHOUSE {entity};",
        "rollback_template": "ALTER WAREHOUSE {entity} SET AUTO_SUSPEND = {original_value};",
        "requires_role": "SYSADMIN",
        "audit_table": "OVERWATCH_REMEDIATION_LOG",
