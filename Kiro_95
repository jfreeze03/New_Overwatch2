# utils/compliance.py

CIS_SNOWFLAKE_CONTROLS = [
    {"id": "1.1", "control": "Network policy exists", "check_sql": "SHOW NETWORK POLICIES", "pass_condition": "row_count > 0"},
    {"id": "1.2", "control": "MFA enabled for all admins", "check_sql": "SELECT COUNT_IF(has_mfa = FALSE) FROM ...", "pass_condition": "value == 0"},
    {"id": "2.1", "control": "No PUBLIC grants on sensitive objects", "check_sql": "...", "pass_condition": "row_count == 0"},
    {"id": "2.2", "control": "ACCOUNTADMIN not used for daily operations", "check_sql": "...", "pass_condition": "value < 5"},
    {"id": "3.1", "control": "All data encrypted at rest", "check_sql": "...", "pass_condition": "always_true"},
    {"id": "4.1", "control": "Audit logging enabled", "check_sql": "...", "pass_condition": "value == TRUE"},
    # ... 20+ controls
]

def run_compliance_assessment(session) -> dict:
    """Run CIS Snowflake Benchmark checks and return compliance percentage."""
    results = []
    for control in CIS_SNOWFLAKE_CONTROLS:
        try:
            df = session.sql(control["check_sql"]).collect()
            passed = evaluate_condition(df, control["pass_condition"])
        except Exception:
            passed = None  # Could not evaluate
        results.append({**control, "passed": passed})
    
    total = len(results)
    passed = sum(1 for r in results if r["passed"] is True)
    return {
        "compliance_pct": round(100 * passed / total, 1),
        "controls_passed": passed,
        "controls_failed": sum(1 for r in results if r["passed"] is False),
        "controls_unknown": sum(1 for r in results if r["passed"] is None),
        "total_controls": total,
        "details": results,
    }
