def _check_query_budget() -> bool:
    """Return False if the current render cycle has exceeded query budget."""
    now = time.time()
    reset_at = st.session_state.get(_QUERY_CYCLE_RESET_KEY, 0)
    if now - reset_at > 5:  # Reset every 5 seconds (one Streamlit rerun)
        st.session_state[_QUERY_CYCLE_COUNTER_KEY] = 0
        st.session_state[_QUERY_CYCLE_RESET_KEY] = now
    count = st.session_state.get(_QUERY_CYCLE_COUNTER_KEY, 0)
    if count >= _MAX_QUERIES_PER_RENDER_CYCLE:
        return False
    st.session_state[_QUERY_CYCLE_COUNTER_KEY] = count + 1
    return True
```

