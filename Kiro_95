```python
import numpy as np
from datetime import date, timedelta

def linear_credit_forecast(
    daily_credits: list[tuple[date, float]],
    forecast_days: int = 90,
) -> dict:
    """Simple linear regression forecast on daily credit consumption."""
    if len(daily_credits) < 7:
        return {"confidence": "insufficient_data"}
    
    dates = [d[0] for d in daily_credits]
    credits = [d[1] for d in daily_credits]
    x = np.array([(d - dates[0]).days for d in dates], dtype=float)
    y = np.array(credits, dtype=float)
    
    # Linear regression
    n = len(x)
    slope = (n * np.sum(x * y) - np.sum(x) * np.sum(y)) / (n * np.sum(x**2) - np.sum(x)**2)
    intercept = (np.sum(y) - slope * np.sum(x)) / n
    
    # Forecast
    last_day = (dates[-1] - dates[0]).days
    forecast_x = np.arange(last_day + 1, last_day + forecast_days + 1)
    forecast_y = slope * forecast_x + intercept
    
    # Commitment exhaustion
    annual_commitment = float(st.session_state.get("annual_credit_commitment", 0))
    ytd_consumed = sum(credits)
    daily_burn_rate = slope if slope > 0 else np.mean(credits)
    remaining = annual_commitment - ytd_consumed
    days_until_exhaustion = int(remaining / daily_burn_rate) if daily_burn_rate > 0 else None
    
    return {
        "daily_burn_rate": round(float(daily_burn_rate), 2),
        "projected_30d": round(float(daily_burn_rate * 30), 2),
        "projected_90d": round(float(daily_burn_rate * 90), 2),
        "annual_projected": round(float(daily_burn_rate * 365), 2),
        "commitment_exhaustion_date": (date.today() + timedelta(days=days_until_exhaustion)) if days_until_exhaustion else None,
        "ytd_consumed": round(ytd_consumed, 2),
        "trend_direction": "increasing" if slope > 0 else "decreasing",
        "confidence": "high" if len(daily_credits) >= 30 else "moderate",
    }
```

