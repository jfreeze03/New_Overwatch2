def build_query_fingerprint_sql(days_back: int = 14) -> str:
    """Group queries by parameterized template fingerprint."""
    return f"""
    SELECT
        query_parameterized_hash AS fingerprint,
        ANY_VALUE(query_text) AS sample_query_text,
        COUNT(*) AS execution_count,
        SUM(total_elapsed_time) / 1000 AS total_elapsed_sec,
        AVG(total_elapsed_time) / 1000 AS avg_elapsed_sec,
        SUM(bytes_scanned) / POWER(1024, 3) AS total_gb_scanned,
        SUM(bytes_spilled_to_remote_storage) / POWER(1024, 3) AS total_remote_spill_gb,
        COUNT(DISTINCT user_name) AS distinct_users,
        COUNT(DISTINCT warehouse_name) AS distinct_warehouses,
        MAX(warehouse_name) AS primary_warehouse
    FROM SNOWFLAKE.ACCOUNT_USAGE.QUERY_HISTORY
    WHERE start_time >= DATEADD('day', -{days_back}, CURRENT_TIMESTAMP())
      AND query_parameterized_hash IS NOT NULL
      AND execution_status = 'SUCCESS'
    GROUP BY fingerprint
    ORDER BY total_elapsed_sec DESC
    LIMIT 50
    """
